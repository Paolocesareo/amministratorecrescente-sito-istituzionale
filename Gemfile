source "https://rubygems.org"

# GitHub Pages: questa gem tiene allineate le versioni di Jekyll e plugin
# con quelle usate dai server di GitHub Pages. Non cambiarla a mano.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
end
